POSTGRES_DB=gymtrackerdb
POSTGRES_USER=gymuser
POSTGRES_PASSWORD=change-me
POSTGRES_VOLUME_NAME=gym-tracker_gym-tracker-postgres-data
POSTGRES_BACKUP_VOLUME_NAME=gym-tracker_gym-tracker-postgres-backups
POSTGRES_BACKUP_RETENTION_COUNT=7
POSTGRES_BACKUP_INTERVAL_SECONDS=86400
# Required: random secret at least 32 characters long.
JWT_SIGNING_KEY=replace-with-a-random-secret-at-least-32-characters-long
JWT_ISSUER=gym-tracker-api
JWT_AUDIENCE=gym-tracker-app
JWT_EXPIRATION_HOURS=24
LEGACY_USER_EMAIL=
LEGACY_USER_PASSWORD=
APP_BASE_URL=http://localhost:8080
WEB_PORT=8080
Wger__Enabled=true
Wger__BaseUrl=https://wger.de/api/v2/
Wger__LanguageId=2
Wger__LanguageCode=en
Wger__PageSize=50
Wger__MaxItems=1000
ExerciseMediaEnrichment__MaxItems=250
ExerciseMediaEnrichment__Wger__Enabled=true
ExerciseMediaEnrichment__ExerciseDb__Enabled=false
ExerciseMediaEnrichment__ExerciseDb__BaseUrl=
ExerciseMediaEnrichment__ExerciseDb__ExercisePath=/exercises
ExerciseMediaEnrichment__ExerciseDb__AssetBaseUrl=
ExerciseMediaEnrichment__ExerciseDb__MaxDatasetItems=2500
# Example custom headers when the fallback provider needs them:
# ExerciseMediaEnrichment__ExerciseDb__RequestHeaders__X-RapidAPI-Key=your-key
# ExerciseMediaEnrichment__ExerciseDb__RequestHeaders__X-RapidAPI-Host=example-host
