{
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:4173",
      "http://localhost:8080"
    ]
  },
  "Http": {
    "UseHttpsRedirection": false
  },
  "Jwt": {
    "Issuer": "gym-tracker-api",
    "Audience": "gym-tracker-app",
    "ExpirationHours": 24
  },
  "Wger": {
    "Enabled": true,
    "BaseUrl": "https://wger.de/api/v2/",
    "LanguageId": 2,
    "LanguageCode": "en",
    "PageSize": 50,
    "MaxItems": 250
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
