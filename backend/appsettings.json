{
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:4173",
      "http://localhost:8080"
    ]
  },
  "Http": {
    "UseHttpsRedirection": false
  },
  "Jwt": {
    "Issuer": "gym-tracker-api",
    "Audience": "gym-tracker-app",
    "ExpirationHours": 24
  },
  "Wger": {
    "Enabled": true,
    "BaseUrl": "https://wger.de/api/v2/",
    "LanguageId": 2,
    "LanguageCode": "en",
    "PageSize": 50,
    "MaxItems": 1000
  },
  "ExerciseMediaEnrichment": {
    "MaxItems": 250,
    "Wger": {
      "Enabled": true
    },
    "ExerciseDb": {
      "Enabled": false,
      "BaseUrl": "",
      "ExercisePath": "/exercises",
      "AssetBaseUrl": "",
      "MaxDatasetItems": 2500,
      "RequestHeaders": {}
    },
    "FreeExerciseDb": {
      "Enabled": true,
      "BaseUrl": "https://raw.githubusercontent.com/yuhonas/free-exercise-db/main/",
      "ExercisePath": "dist/exercises.json",
      "AssetBaseUrl": "https://raw.githubusercontent.com/yuhonas/free-exercise-db/main/exercises/",
      "MaxDatasetItems": 2500,
      "RequestHeaders": {}
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
